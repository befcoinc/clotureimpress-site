DATABASE_URL=postgresql://user:password@host:5432/dbname
# Dév local avec Docker (dans ce dossier : docker compose up -d) :
# DATABASE_URL=postgresql://crm:crm@127.0.0.1:5432/crm_cloture
NODE_ENV=development
INTIMURA_COOKIE=
# Sync auto serveur (minutes entre chaque verification Intimura, defaut 5)
INTIMURA_AUTO_SYNC_MINUTES=5
# Token Cloudflare Access (recommande pour sync auto — ne expire pas comme le cookie)
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=
INTIMURA_BOOKMARKLET_TOKEN=
# Clé API Anthropic — requis pour le script d'appel IA (fonctionne en mode template sans clé)
ANTHROPIC_API_KEY=sk-ant-...
# Mapbox — token public (carte + géocodage ultra-précis Canada)
# Crée un compte gratuit sur mapbox.com → Dashboard → Default public token
VITE_MAPBOX_TOKEN=pk.votre_token_mapbox_public
MAPBOX_TOKEN=pk.votre_token_mapbox_public
STRIPE_SECRET_KEY=sk_live_...
